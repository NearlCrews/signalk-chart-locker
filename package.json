{
  "name": "signalk-chart-locker",
  "version": "0.4.3",
  "description": "Signal K plugin that runs a Rust container alongside the server for a boat-wide tile cache, a PMTiles chart provider, and saved downloadable map regions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public",
    "assets",
    "CHANGELOG.md",
    "docs/API.md",
    "docs/OPERATIONS.md"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:panel",
    "build:plugin": "node scripts/clean-dist.mjs && tsc",
    "build:panel": "webpack --config webpack.config.cjs && node scripts/check-panel-bundle.mjs",
    "watch:panel": "webpack --watch --mode development --config webpack.config.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.panel.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --import tsx --test test/*.test.ts",
    "check:package": "npm run build && node scripts/check-package-contents.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-chart-plotters",
    "signalk-category-utility",
    "container",
    "tile-cache",
    "pmtiles",
    "offline-charts",
    "chartplotter"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Chart Locker",
    "appIcon": "./assets/icons/icon-192.png",
    "screenshots": [
      "./assets/screenshots/config-panel.png",
      "./assets/screenshots/config-panel-dark.png",
      "./assets/screenshots/config-panel-night.png"
    ],
    "requires": [
      "signalk-container"
    ],
    "recommends": [
      "signalk-binnacle"
    ]
  },
  "peerDependencies": {
    "signalk-container": ">=1.20.0"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "author": {
    "name": "Nearl Crews",
    "email": "NearlCrews@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/NearlCrews/signalk-chart-locker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-chart-locker.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-chart-locker/issues"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@signalk/server-api": "^2.30.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "neostandard": "^0.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "pmtiles": "^4.4.1",
    "signalk-chart-sources": "^0.2.1"
  }
}
