{
  "name": "signalk-chart-locker",
  "version": "0.6.1",
  "description": "Signal K plugin that runs a Rust container alongside the server for a boat-wide tile cache, a PMTiles chart provider, and saved downloadable map regions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public",
    "assets",
    "CHANGELOG.md",
    "LICENSE-APACHE",
    "RUST_THIRD_PARTY_LICENSES.md",
    "THIRD_PARTY_NOTICES.md",
    "docs/API.md",
    "docs/OPERATIONS.md"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:panel",
    "build:plugin": "node scripts/clean-dist.mjs && tsc",
    "build:panel": "webpack --config webpack.config.cjs --json .panel-stats.json && node scripts/check-panel-bundle.mjs",
    "watch:panel": "webpack --watch --mode development --config webpack.config.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.panel.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.browser.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node scripts/run-node-tests.mjs",
    "test:node-rust-contract": "node scripts/run-node-rust-contract.mjs",
    "pretest:browser": "npm run build:panel",
    "test:browser": "playwright test --project=chromium",
    "pretest:browser:cross": "npm run build:panel",
    "test:browser:cross": "playwright test",
    "test:integration": "node scripts/check-signalk-integration.mjs",
    "screenshots": "npm run build:panel && node scripts/capture-panel-screenshots.mjs",
    "licenses:rust:update": "node scripts/rust-license-report.mjs --write",
    "licenses:rust:check": "node scripts/rust-license-report.mjs",
    "check:package": "npm run build && node scripts/check-package-contents.mjs",
    "verify:publish": "npm run licenses:rust:check && npm run typecheck && npm run lint && npm test && npm run test:browser:cross && npm audit && npm run check:package",
    "pack:release": "node scripts/create-release-tarball.mjs",
    "verify:release-tarball": "node scripts/verify-release-tarball.mjs",
    "prepublishOnly": "npm run verify:publish"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-plugin-configurator",
    "signalk-category-chart-plotters",
    "signalk-category-utility",
    "container",
    "tile-cache",
    "pmtiles",
    "offline-charts",
    "chartplotter"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Chart Locker",
    "appIcon": "./assets/icons/icon-192.png",
    "screenshots": [
      "./assets/screenshots/config-panel.png",
      "./assets/screenshots/config-panel-dark.png",
      "./assets/screenshots/config-panel-night.png"
    ],
    "requires": [
      "signalk-container"
    ],
    "recommends": [
      "signalk-binnacle"
    ]
  },
  "peerDependencies": {
    "@signalk/server-api": ">=2.24.0 <3",
    "signalk-container": ">=1.20.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Nearl Crews <NearlCrews@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/NearlCrews/signalk-chart-locker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-chart-locker.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-chart-locker/issues"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@signalk/server-api": "^2.30.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "neostandard": "^0.13.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "signalk-nearlcrews-ui": "0.3.0",
    "style-loader": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "pmtiles": "^4.4.1",
    "signalk-chart-sources": "^0.4.0"
  },
  "allowScripts": {
    "cpu-features": false,
    "esbuild@0.28.1": true,
    "protobufjs": false,
    "ssh2": false
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "type": "commonjs"
}
